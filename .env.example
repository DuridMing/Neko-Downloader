# Neko Downloader 設定範例
# 複製為 .env 後修改：cp .env.example .env
# 優先序：環境變數 > .env > config.json > 程式預設值

# 同時下載的任務數
MAX_CONCURRENT=2

# 佇列上限，滿了回 429
MAX_QUEUE_SIZE=50

# 完成檔案的保留秒數，逾時自動刪除（失敗/取消的記錄同樣依此 TTL 從佇列消失）
FILE_TTL_SECONDS=3600

# 清理排程的掃描間隔（秒）
CLEANUP_INTERVAL_SECONDS=60

# 瀏覽器嗅探的等待上限（秒）：載入網頁後等待媒體串流請求出現的時間
SNIFF_TIMEOUT_SECONDS=20

# Netscape 格式的 cookies 檔路徑（選填）：抓取需要登入的內容時使用
# （如私人 Facebook/X/TikTok 貼文）。可用 ./scripts/get-cookies.sh 互動式登入產生，
# 或瀏覽器擴充功能「Get cookies.txt」匯出
#COOKIES_FILE=/path/to/cookies.txt

# 或直接讀取本機瀏覽器的登入 cookies（選填，僅限主機直裝、瀏覽器在同一台機器）
# 支援 chrome / firefox / edge / brave / chromium…，可加 profile 如 "chrome:Profile 1"
# 兩者都設時以 COOKIES_FILE 優先
#COOKIES_FROM_BROWSER=firefox

# 審查日誌檔路徑（JSON Lines 格式，自動輪替 10MB x 5）
# 相對路徑以 backend/ 為基準；設為空字串可停用檔案輸出（stdout 仍會輸出）
AUDIT_LOG_FILE=logs/audit.log

# 暫存目錄（docker-compose 已對此路徑掛 tmpfs）
TMP_DIR=/tmp/neko_dl

# 服務埠
PORT=8000

# ── macvlan 部署專用（搭配 docker-compose.macvlan.yml，bridge 模式不需要）──
# 實體網卡名稱（用 `ip link` 查詢）
MACVLAN_PARENT=eth0
# 區網網段與閘道
MACVLAN_SUBNET=192.168.1.0/24
MACVLAN_GATEWAY=192.168.1.1
# 分配給容器的固定 IP（避開 DHCP 派發範圍）
MACVLAN_IP=192.168.1.50
